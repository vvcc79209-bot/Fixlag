local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- Tối ưu Lighting & Terrain (giữ mặt biển + đất)
Lighting.GlobalShadows = false
Lighting.FogEnd = 100000
Lighting.Brightness = 2
Lighting.ClockTime = 12
Lighting.EnvironmentDiffuseScale = 0
Lighting.EnvironmentSpecularScale = 0
Lighting.ShadowSoftness = 0

Workspace.Terrain.WaterWaveSize = 0
Workspace.Terrain.WaterWaveSpeed = 0
Workspace.Terrain.WaterReflectance = 0
Workspace.Terrain.WaterTransparency = 0.6   -- Giữ mặt biển không mất

-- Hàm xóa 90% hiệu ứng, 10% chuyển xám
local function optimizeEffects(obj)
	for _, v in ipairs(obj:GetDescendants()) do
		pcall(function()
			if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Sparkles") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Explosion") or v:IsA("PointLight") then
				if math.random(1, 100) <= 90 then
					v:Destroy()
				else
					if v:IsA("ParticleEmitter") then
						v.Color = ColorSequence.new(Color3.fromRGB(100, 100, 100))
						v.LightEmission = 0
						v.Rate = math.max(1, v.Rate / 8)
						v.Lifetime = NumberRange.new(0.3, 0.8)
					elseif v:IsA("Trail") or v:IsA("Beam") then
						v.Color = ColorSequence.new(Color3.fromRGB(100, 100, 100))
						v.LightEmission = 0
						v.Transparency = NumberSequence.new(0.6)
					end
				end
			end
		end)
	end
end

-- Xóa cây, nhà, phụ kiện map (KHÔNG chạm Terrain)
local function cleanMap()
	pcall(function()
		for _, v in ipairs(Workspace:GetDescendants()) do
			if (v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Model")) and not v:IsDescendantOf(Workspace.Terrain) then
				local n = v.Name:lower()
				if n:find("tree") or n:find("bush") or n:find("plant") or n:find("house") or n:find("building") or 
				   n:find("rock") or n:find("fence") or n:find("debris") or n:find("prop") or n:find("decoration") then
					v:Destroy()
				end
			end
		end
	end)
end

-- Xóa phụ kiện + biến NPC/Player thành xám
local function grayAndCleanCharacter(char)
	pcall(function()
		-- Xóa phụ kiện
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Accessory") or item:IsA("Hat") or item:IsA("Clothing") or item.Name:find("Accessory") then
				item:Destroy()
			end
		end
		
		-- Chuyển xám
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") and part.Name \~= "HumanoidRootPart" then
				part.Color = Color3.fromRGB(105, 105, 105)
				part.Material = Enum.Material.Plastic
				part.Reflectance = 0
			end
		end
	end)
end

-- Áp dụng cho tất cả người chơi
for _, plr in ipairs(Players:GetPlayers()) do
	if plr.Character then grayAndCleanCharacter(plr.Character) end
	plr.CharacterAdded:Connect(grayAndCleanCharacter)
end

-- Áp dụng cho NPC
local function applyToNPCs()
	for _, v in ipairs(Workspace:GetDescendants()) do
		if v:IsA("Model") and v:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(v) then
			grayAndCleanCharacter(v)
		end
	end
end

-- Fix camera Levi + anti xoay CDK
local function fixCameraAndSpin()
	pcall(function()
		if Camera.CameraType == Enum.CameraType.Scriptable then
			Camera.CameraType = Enum.CameraType.Custom
		end
		if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
			LocalPlayer.Character.HumanoidRootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)
		end
	end)
end

-- Main loop nhẹ (Heartbeat của Delta chạy tốt)
RunService.Heartbeat:Connect(function()
	pcall(function()
		optimizeEffects(Workspace)
		optimizeEffects(ReplicatedStorage)
		fixCameraAndSpin()
	end)
end)

-- Khởi chạy một lần
task.spawn(function()
	optimizeEffects(Workspace)
	optimizeEffects(ReplicatedStorage)
	cleanMap()
	applyToNPCs()

	Workspace.DescendantAdded:Connect(function(desc)
		if desc:IsA("ParticleEmitter") or desc:IsA("Trail") or desc:IsA("Beam") then
			task.wait(0.08)
			optimizeEffects(desc.Parent or desc)
		end
	end)

	print("✅ Fix Lag Blox Fruits - Delta Executor loaded thành công!")
	print("   • 90% hiệu ứng skill + đánh thường đã xóa")
	print("   • 10% còn lại chuyển màu xám")
	print("   • Cây cối, nhà cửa, phụ kiện map đã dọn sạch")
	print("   • NPC & Players thành xám + không phụ kiện")
	print("   • Fix cam Levi, không mất biển/đất, không xoay khi dùng CDK")
	print("   • Tối ưu cho Delta - Không drop FPS")
end)
