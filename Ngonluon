--// CLEAN FIX LAG (SAFE - KHÔNG PHÁ MAP)

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local gray = Color3.fromRGB(110,110,110)

--// XOÁ EFFECT 100%
local function removeEffects(obj)
    if obj:IsA("ParticleEmitter")
    or obj:IsA("Trail")
    or obj:IsA("Smoke")
    or obj:IsA("Fire")
    or obj:IsA("Sparkles")
    or obj:IsA("Beam")
    or obj:IsA("Explosion") then
        obj:Destroy()
    end
end

--// XOÁ SOUND
local function removeSound(obj)
    if obj:IsA("Sound") then
        obj:Destroy()
    end
end

--// XOÁ CÂY + NHÀ + TRANG TRÍ (KHÔNG ĐỤNG MAP CHÍNH)
local function removeTrash(obj)
    if obj:IsA("Model") then
        local name = string.lower(obj.Name)

        if string.find(name, "tree")
        or string.find(name, "plant")
        or string.find(name, "bush")
        or string.find(name, "house")
        or string.find(name, "building")
        or string.find(name, "decoration")
        or string.find(name, "grass") then
            obj:Destroy()
        end
    end
end

--// TỐI GIẢN PART + ĐỔI MÀU
local function optimizePart(obj)
    if obj:IsA("BasePart") then
        local name = string.lower(obj.Name)

        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0
        obj.CastShadow = false

        -- 🌊 BIỂN
        if string.find(name, "water") or string.find(name, "sea") then
            obj.Color = gray
        end

        -- 🌍 MẶT ĐẤT
        if string.find(name, "ground")
        or string.find(name, "island")
        or string.find(name, "sand")
        or string.find(name, "floor") then
            obj.Color = gray
        end
    end
end

--// XOÁ TEXTURE NHẸ (KHÔNG PHÁ MAP)
local function removeTexture(obj)
    if obj:IsA("Decal") or obj:IsA("Texture") then
        obj:Destroy()
    end
end

--// APPLY
for _,v in pairs(workspace:GetDescendants()) do
    pcall(function()
        removeEffects(v)
        removeSound(v)
        removeTrash(v)
        removeTexture(v)
        optimizePart(v)
    end)
end

--// ANTI EFFECT SPAWN
workspace.DescendantAdded:Connect(function(v)
    task.wait()
    pcall(function()
        removeEffects(v)
        removeSound(v)
        removeTexture(v)
        optimizePart(v)
    end)
end)

--// LIGHT (KHÔNG ĐỤNG SUN)
pcall(function()
    local l = game:GetService("Lighting")
    l.GlobalShadows = false
    l.FogEnd = 9e9
    l.Brightness = 1
end)

--// FPS BOOST
pcall(function()
    settings().Rendering.QualityLevel = 1
end)

print("✅ FIX LAG STABLE DONE").
