--// FULL LAG FIX BLOX FRUITS (NO EFFECT + REMOVE TREE/HOUSE + GRAY MAP)

-- Chờ game load
repeat task.wait() until game:IsLoaded()

-- Settings
local REMOVE_EFFECT = true
local REMOVE_TREE = true
local REMOVE_HOUSE = true
local GRAY_WORLD = true

-- Hàm check giữ lại mặt đất
local function isImportantPart(v)
    if not v:IsA("BasePart") then return false end
    
    local name = v.Name:lower()
    
    -- Giữ lại mặt đất, map chính
    if name:find("ground") or name:find("floor") or name:find("terrain") then
        return true
    end
    
    -- giữ terrain
    if v:IsDescendantOf(workspace.Terrain) then
        return true
    end
    
    return false
end

-- 1. XOÁ HIỆU ỨNG (skill, đánh thường, trái, kiếm, súng)
if REMOVE_EFFECT then
    for _,v in pairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter") 
        or v:IsA("Trail") 
        or v:IsA("Beam") 
        or v:IsA("Explosion") 
        or v:IsA("Fire") 
        or v:IsA("Smoke") 
        or v:IsA("Sparkles") then
            v:Destroy()
        end

        -- Tắt ánh sáng
        if v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
            v.Enabled = false
        end
    end
end

-- 2. XOÁ CÂY + NHÀ
if REMOVE_TREE or REMOVE_HOUSE then
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") then
            local name = v.Name:lower()

            if REMOVE_TREE and (name:find("tree") or name:find("bush") or name:find("plant")) then
                v:Destroy()
            elseif REMOVE_HOUSE and (name:find("house") or name:find("building") or name:find("home")) then
                v:Destroy()
            end
        end
    end
end

-- 3. BIẾN MAP THÀNH MÀU XÁM (ĐẤT + BIỂN)
if GRAY_WORLD then
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            if isImportantPart(v) then
                v.Color = Color3.fromRGB(120,120,120)
                v.Material = Enum.Material.SmoothPlastic
            end
        end
    end

    -- Terrain (biển + đất)
    if workspace:FindFirstChildOfClass("Terrain") then
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        terrain.WaterColor = Color3.fromRGB(120,120,120)
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0.3
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
    end
end

-- 4. FIX CDK (giảm lỗi xoay + bug skill)
-- Không xoá animation + body movers
for _,v in pairs(game:GetDescendants()) do
    if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then
        v.MaxForce = Vector3.new(0,0,0)
    end
end

print("✅ Lag Fix Loaded - Full Remove Effects + Remove Tree/House + Gray Map")
