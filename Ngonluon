--// EXTREME CLEAN MAP - MAX FPS

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local gray = Color3.fromRGB(100,100,100)

--// CHECK MẶT ĐẤT (KHÔNG XOÁ)
local function isImportantPart(obj)
    if not obj:IsA("BasePart") then return false end
    
    local name = string.lower(obj.Name)
    
    return string.find(name, "ground")
        or string.find(name, "island")
        or string.find(name, "sand")
        or string.find(name, "floor")
        or string.find(name, "base")
end

--// XỬ LÝ OBJECT
local function clean(obj)
    pcall(function()

        -- ❌ XOÁ EFFECT 100%
        if obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Smoke")
        or obj:IsA("Fire")
        or obj:IsA("Sparkles")
        or obj:IsA("Beam")
        or obj:IsA("Explosion") then
            obj:Destroy()
            return
        end

        -- ❌ XOÁ SOUND
        if obj:IsA("Sound") then
            obj:Destroy()
            return
        end

        -- ❌ XOÁ TEXTURE
        if obj:IsA("Decal") or obj:IsA("Texture") then
            obj:Destroy()
            return
        end

        -- ❌ XOÁ MODEL KHÔNG CẦN THIẾT
        if obj:IsA("Model") then
            local name = string.lower(obj.Name)

            if not string.find(name, "player")
            and not string.find(name, "character")
            and not string.find(name, "npc") then
                obj:Destroy()
                return
            end
        end

        -- ⚙️ XỬ LÝ PART
        if obj:IsA("BasePart") then
            local name = string.lower(obj.Name)

            -- 🌊 BIỂN
            if string.find(name, "water") or string.find(name, "sea") then
                obj.Color = gray
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
                obj.CastShadow = false
                return
            end

            -- 🌍 MẶT ĐẤT
            if isImportantPart(obj) then
                obj.Color = gray
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
                obj.CastShadow = false
                return
            end

            -- ❌ XOÁ PART KHÁC
            obj:Destroy()
        end

    end)
end

--// APPLY
for _,v in pairs(workspace:GetDescendants()) do
    clean(v)
end

--// ANTI SPAWN (XOÁ NGAY)
workspace.DescendantAdded:Connect(function(v)
    task.wait()
    clean(v)
end)

--// LIGHT (KHÔNG ĐỤNG MẶT TRỜI)
pcall(function()
    local l = game:GetService("Lighting")
    l.GlobalShadows = false
    l.FogEnd = 9e9
    l.Brightness = 1
end)

--// FPS BOOST
pcall(function()
    settings().Rendering.QualityLevel = 1
end)

print("💀 EXTREME CLEAN DONE")
