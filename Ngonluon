--// FIX LAG BLOX FRUITS - CUSTOM

if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- SETTINGS
local REMOVE_EFFECT_PERCENT = 0.9

-- SERVICES
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")

--// 1. GIẢM HIỆU ỨNG
for _, v in pairs(game:GetDescendants()) do
    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
        if math.random() < REMOVE_EFFECT_PERCENT then
            v.Enabled = false
        else
            v.Color = ColorSequence.new(Color3.fromRGB(120,120,120))
        end
    end

    if v:IsA("Explosion") or v:IsA("Fire") or v:IsA("Smoke") then
        v:Destroy()
    end
end

--// 2. BIẾN PLAYER + NPC THÀNH MÀU XÁM
local function grayCharacter(char)
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Color = Color3.fromRGB(120,120,120)
            part.Material = Enum.Material.SmoothPlastic
        end
    end
end

for _, plr in pairs(Players:GetPlayers()) do
    if plr.Character then
        grayCharacter(plr.Character)
    end
    plr.CharacterAdded:Connect(grayCharacter)
end

-- NPC
for _, v in pairs(Workspace:GetDescendants()) do
    if v:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(v) then
        grayCharacter(v)
    end
end

--// 3. XOÁ PHỤ KIỆN
local function removeAccessories(char)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Accessory") then
            v:Destroy()
        end
    end
end

for _, plr in pairs(Players:GetPlayers()) do
    if plr.Character then
        removeAccessories(plr.Character)
    end
    plr.CharacterAdded:Connect(removeAccessories)
end

--// 4. XOÁ CÂY + NHÀ NHẸ (KHÔNG XOÁ MAP CHÍNH)
for _, v in pairs(Workspace:GetDescendants()) do
    if v:IsA("Model") then
        local name = string.lower(v.Name)
        if name:find("tree") or name:find("house") or name:find("building") then
            v:Destroy()
        end
    end
end

--// 5. GIỮ NGUYÊN MẶT ĐẤT + BIỂN (KHÔNG ĐỤNG TERRAIN)
-- Không xóa Terrain để tránh lỗi Levi / biển / map

--// 6. GIẢM ÁNH SÁNG
Lighting.GlobalShadows = false
Lighting.FogEnd = 100000
Lighting.Brightness = 1

for _, v in pairs(Lighting:GetDescendants()) do
    if v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") then
        v.Enabled = false
    end
end

--// 7. ANTI LAG FPS DROP
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

--// DONE
print("✅ Fix lag loaded - 90% effect removed")
