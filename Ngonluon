--// ULTRA FIX LAG 100% - NO EFFECT / NO SOUND / CLEAN MAP

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local gray = Color3.fromRGB(110,110,110)

--// SAFE CHECK GROUND (KHÔNG XOÁ)
local function isGround(part)
    local name = string.lower(part.Name)
    return string.find(name, "ground")
        or string.find(name, "island")
        or string.find(name, "sand")
        or string.find(name, "floor")
end

--// REMOVE EVERYTHING USELESS
local function nuke(obj)
    pcall(function()

        -- ❌ XOÁ 100% EFFECT
        if obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Smoke")
        or obj:IsA("Fire")
        or obj:IsA("Sparkles")
        or obj:IsA("Beam")
        or obj:IsA("Explosion") then
            obj:Destroy()
        end

        -- ❌ XOÁ 100% SOUND
        if obj:IsA("Sound") then
            obj:Destroy()
        end

        -- ❌ XOÁ CÂY + NHÀ + TRANG TRÍ
        if obj:IsA("Model") then
            local name = string.lower(obj.Name)

            if string.find(name, "tree")
            or string.find(name, "plant")
            or string.find(name, "bush")
            or string.find(name, "house")
            or string.find(name, "building")
            or string.find(name, "decoration")
            or string.find(name, "grass") then
                obj:Destroy()
            end
        end

        -- ❌ XOÁ TEXTURE / DECAL (GIẢM LAG CỰC MẠNH)
        if obj:IsA("Decal") or obj:IsA("Texture") then
            obj:Destroy()
        end

        -- ⚙️ TỐI GIẢN PART
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow = false

            local name = string.lower(obj.Name)

            -- 🌊 BIỂN → XÁM
            if string.find(name, "water") or string.find(name, "sea") then
                obj.Color = gray
            end

            -- 🌍 MẶT ĐẤT → XÁM (KHÔNG XOÁ)
            if isGround(obj) then
                obj.Color = gray
            end
        end

    end)
end

--// APPLY ALL
for _,v in pairs(workspace:GetDescendants()) do
    nuke(v)
end

--// ANTI SPAWN (QUAN TRỌNG: XOÁ SKILL NGAY LẬP TỨC)
workspace.DescendantAdded:Connect(function(v)
    task.wait()
    nuke(v)
end)

--// LIGHT FIX (KHÔNG ĐỤNG MẶT TRỜI)
pcall(function()
    local l = game:GetService("Lighting")
    l.GlobalShadows = false
    l.FogEnd = 9e9
    l.Brightness = 1
end)

--// FPS BOOST EXTRA
pcall(function()
    settings().Rendering.QualityLevel = 1
end)

print("🔥 ULTRA FIX LAG 100% DONE")
