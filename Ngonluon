if not game:IsLoaded() then
    game.Loaded:Wait()
end

--// SETTINGS
local grayColor = Color3.fromRGB(120,120,120)

--// FUNCTION: REMOVE EFFECTS
local function removeEffects(obj)
    if obj:IsA("ParticleEmitter")
    or obj:IsA("Trail")
    or obj:IsA("Smoke")
    or obj:IsA("Fire")
    or obj:IsA("Sparkles")
    or obj:IsA("Beam") then
        obj:Destroy()
    end
end

--// FUNCTION: REMOVE SOUND
local function removeSound(obj)
    if obj:IsA("Sound") then
        obj:Destroy()
    end
end

--// FUNCTION: SIMPLIFY PART
local function simplifyPart(obj)
    if obj:IsA("BasePart") then
        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0
        obj.CastShadow = false
    end
end

--// FUNCTION: REMOVE TREE + BUILDING
local function removeMapTrash(obj)
    if obj:IsA("Model") then
        local name = string.lower(obj.Name)

        if string.find(name, "tree")
        or string.find(name, "plant")
        or string.find(name, "bush")
        or string.find(name, "house")
        or string.find(name, "building") then
            obj:Destroy()
        end
    end
end

--// APPLY TO MAP
for _,v in pairs(workspace:GetDescendants()) do
    pcall(function()

        -- xoá hiệu ứng
        removeEffects(v)

        -- xoá âm thanh
        removeSound(v)

        -- xoá cây + nhà
        removeMapTrash(v)

        -- tối ưu part
        simplifyPart(v)

        -- đổi màu biển + mặt đất
        if v:IsA("BasePart") then
            local name = string.lower(v.Name)

            if string.find(name, "water")
            or string.find(name, "sea") then
                v.Color = grayColor
                v.Material = Enum.Material.SmoothPlastic
            end

            -- mặt đất (không xoá)
            if string.find(name, "ground")
            or string.find(name, "island")
            or string.find(name, "sand") then
                v.Color = grayColor
                v.Material = Enum.Material.SmoothPlastic
            end
        end

    end)
end

--// ANTI NEW EFFECT
workspace.DescendantAdded:Connect(function(v)
    task.wait()

    pcall(function()
        removeEffects(v)
        removeSound(v)
        simplifyPart(v)
    end)
end)

